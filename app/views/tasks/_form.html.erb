<%# Shared Task Form %>
<% priority_colors = { "low" => "bg-slate-100 text-slate-600 border-slate-200",
                       "medium" => "bg-blue-100 text-blue-700 border-blue-200",
                       "high" => "bg-amber-100 text-amber-700 border-amber-200",
                       "urgent" => "bg-rose-100 text-rose-700 border-rose-200" } %>

<%= form_with model: [@project, task], class: "space-y-6" do |f| %>

  <%# Validation errors %>
  <% if task.errors.any? %>
    <div class="flex gap-3 p-4 bg-rose-50 border border-rose-200 rounded-xl text-sm text-rose-700">
      <ul class="list-disc list-inside space-y-0.5">
        <% task.errors.full_messages.each do |msg| %><li><%= msg %></li><% end %>
      </ul>
    </div>
  <% end %>

  <%# Title %>
  <div>
    <%= f.label :title, class: "block text-sm font-semibold text-slate-700 mb-1.5" %>
    <%= f.text_field :title, placeholder: "What needs to be done?",
          class: "block w-full px-4 py-2.5 rounded-xl border border-slate-200 text-slate-800
                  text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 transition" %>
  </div>

  <%# Description (Action Text rich editor) %>
  <div>
    <%= f.label :description, class: "block text-sm font-semibold text-slate-700 mb-1.5" %>
    <%= f.rich_text_area :description,
          class: "block w-full rounded-xl border border-slate-200 text-slate-800 text-sm
                  focus:outline-none focus:ring-2 focus:ring-indigo-500 transition min-h-[140px]" %>
  </div>

  <%# Status + Priority + Due date — 3-col grid %>
  <div class="grid sm:grid-cols-3 gap-4">

    <div>
      <%= f.label :status, class: "block text-sm font-semibold text-slate-700 mb-1.5" %>
      <%= f.select :status, Task.statuses.keys.map { |s| [s.humanize.gsub("_", " "), s] }, {},
            class: "block w-full px-4 py-2.5 rounded-xl border border-slate-200 bg-white
                    text-slate-800 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 transition" %>
    </div>

    <div>
      <%= f.label :priority, class: "block text-sm font-semibold text-slate-700 mb-1.5" %>
      <%= f.select :priority, Task.priorities.keys.map { |p| [p.humanize, p] }, {},
            class: "block w-full px-4 py-2.5 rounded-xl border border-slate-200 bg-white
                    text-slate-800 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 transition" %>
    </div>

    <div>
      <%= f.label :due_date, class: "block text-sm font-semibold text-slate-700 mb-1.5" %>
      <%= f.date_field :due_date,
            class: "block w-full px-4 py-2.5 rounded-xl border border-slate-200 bg-white
                    text-slate-800 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 transition" %>
    </div>

  </div>

  <%# Assignee %>
  <div>
    <%= f.label :assignee_id, "Assign to", class: "block text-sm font-semibold text-slate-700 mb-1.5" %>
    <%= f.select :assignee_id,
          @members.map { |u| [u.name || u.email, u.id] },
          { include_blank: "— Unassigned —" },
          class: "block w-full px-4 py-2.5 rounded-xl border border-slate-200 bg-white
                  text-slate-800 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 transition" %>
  </div>

  <%# Labels (multi-checkbox) %>
  <% if @labels.any? %>
    <div>
      <p class="block text-sm font-semibold text-slate-700 mb-2">Labels</p>
      <div class="flex flex-wrap gap-2">
        <% @labels.each do |label| %>
          <label class="flex items-center gap-1.5 cursor-pointer">
            <%= f.check_box :label_ids, { multiple: true, checked: task.labels.include?(label) },
                  label.id, false %>
            <span class="text-xs font-semibold px-2.5 py-1 rounded-full text-white"
                  style="background-color: <%= label.color %>">
              <%= label.name %>
            </span>
          </label>
        <% end %>
      </div>
    </div>
  <% end %>

  <%# Attachments %>
  <div>
    <%= f.label :attachments, "Attachments", class: "block text-sm font-semibold text-slate-700 mb-1.5" %>
    <%= f.file_field :attachments, multiple: true, direct_upload: true,
          class: "block w-full text-sm text-slate-500
                  file:mr-4 file:py-2 file:px-4 file:rounded-xl file:border-0
                  file:text-sm file:font-semibold file:bg-indigo-50 file:text-indigo-700
                  hover:file:bg-indigo-100 transition" %>
  </div>

  <%# Actions %>
  <div class="flex items-center gap-3 pt-2">
    <%= f.submit task.persisted? ? "Save Changes" : "Create Task",
          class: "px-6 py-2.5 bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-semibold
                  rounded-xl shadow-md shadow-indigo-200 transition cursor-pointer" %>
    <%= link_to task.persisted? ? project_task_path(@project, task) : project_tasks_path(@project),
          class: "px-5 py-2.5 text-sm font-semibold text-slate-500 hover:text-slate-700
                  border border-slate-200 rounded-xl hover:bg-slate-50 transition" do %>
      Cancel
    <% end %>
  </div>

<% end %>
