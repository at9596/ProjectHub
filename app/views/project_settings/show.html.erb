<%# Project Settings Page %>
<div class="max-w-3xl mx-auto space-y-8">

  <%# Breadcrumb %>
  <nav class="flex items-center gap-2 text-sm text-slate-400">
    <%= link_to "Projects", projects_path, class: "hover:text-indigo-600 transition" %>
    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
    <%= link_to @project.name, @project, class: "hover:text-indigo-600 transition truncate max-w-[200px]" %>
    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
    <span class="text-slate-600 font-medium">Settings</span>
  </nav>

  <h1 class="text-3xl font-extrabold text-slate-900">Project Settings</h1>

  <%# Members Card %>
  <div class="bg-white border border-slate-100 rounded-2xl shadow-sm overflow-hidden">
    <div class="h-1 w-full bg-gradient-to-r from-indigo-500 via-purple-500 to-pink-500"></div>
    <div class="p-6">
      <h2 class="text-lg font-bold text-slate-800 mb-4">Members</h2>

      <% if @memberships.any? %>
        <ul class="divide-y divide-slate-100 mb-6">
          <% @memberships.each do |m| %>
            <li class="flex items-center justify-between py-3 gap-3">
              <div class="flex items-center gap-3">
                <span class="inline-flex items-center justify-center w-9 h-9 rounded-full bg-indigo-100 text-indigo-600 text-sm font-bold uppercase">
                  <%= (m.user.name || m.user.email).first %>
                </span>
                <div>
                  <p class="text-sm font-semibold text-slate-800"><%= m.user.name || m.user.email %></p>
                  <p class="text-xs text-slate-400"><%= m.role.humanize %></p>
                </div>
              </div>
              <%= button_to project_member_path(@project, m),
                    method: :delete,
                    data: { turbo_confirm: "Remove #{m.user.email} from this project?" },
                    class: "text-xs text-rose-500 hover:text-rose-700 border border-rose-200
                            hover:bg-rose-50 px-3 py-1 rounded-lg transition cursor-pointer" do %>
                Remove
              <% end %>
            </li>
          <% end %>
        </ul>
      <% else %>
        <p class="text-sm text-slate-400 mb-6">No additional members. Add people from your workspace below.</p>
      <% end %>

      <%# Add member form %>
      <% if @org_members.any? %>
        <div class="border-t border-slate-100 pt-5">
          <h3 class="text-sm font-semibold text-slate-700 mb-3">Add a member</h3>
          <%= form_with url: project_project_memberships_path(@project), method: :post, class: "flex flex-wrap gap-3 items-end" do |f| %>
            <div class="flex-1 min-w-[200px]">
              <label class="block text-xs text-slate-500 mb-1">Email from workspace</label>
              <input type="email" name="email" list="org-members-list" placeholder="Search members…"
                     class="block w-full px-4 py-2.5 rounded-xl border border-slate-200 text-slate-800
                             text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 transition">
              <datalist id="org-members-list">
                <% @org_members.each do |u| %>
                  <option value="<%= u.email %>"><%= u.name || u.email %></option>
                <% end %>
              </datalist>
            </div>
            <div>
              <label class="block text-xs text-slate-500 mb-1">Role</label>
              <select name="role" class="px-4 py-2.5 rounded-xl border border-slate-200 text-slate-800
                                          text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 transition bg-white">
                <option value="contributor">Contributor</option>
                <option value="manager">Manager</option>
                <option value="viewer">Viewer</option>
              </select>
            </div>
            <button type="submit" class="px-5 py-2.5 bg-indigo-600 hover:bg-indigo-700 text-white text-sm
                                          font-semibold rounded-xl transition cursor-pointer">
              Add Member
            </button>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>

  <%# Danger Zone %>
  <div class="bg-white border border-rose-200 rounded-2xl shadow-sm overflow-hidden">
    <div class="p-6">
      <h2 class="text-lg font-bold text-rose-600 mb-2">Danger Zone</h2>
      <div class="flex flex-wrap items-center justify-between gap-4">
        <div>
          <p class="text-sm font-semibold text-slate-700">Archive this project</p>
          <p class="text-xs text-slate-400">Archived projects are hidden from the main list but not deleted.</p>
        </div>
        <%= button_to archive_project_path(@project),
              method: :patch,
              data: { turbo_confirm: "Archive \"#{@project.name}\"?" },
              class: "px-5 py-2.5 bg-amber-50 hover:bg-amber-100 text-amber-700 border border-amber-300
                      text-sm font-semibold rounded-xl transition cursor-pointer" do %>
          Archive Project
        <% end %>
      </div>
      <div class="border-t border-rose-100 mt-4 pt-4 flex flex-wrap items-center justify-between gap-4">
        <div>
          <p class="text-sm font-semibold text-slate-700">Delete this project</p>
          <p class="text-xs text-slate-400">This is permanent and cannot be undone.</p>
        </div>
        <% if policy(@project).destroy? %>
          <%= button_to @project,
                method: :delete,
                data: { turbo_confirm: "Permanently delete \"#{@project.name}\"? All tasks will be lost." },
                class: "px-5 py-2.5 bg-rose-50 hover:bg-rose-100 text-rose-700 border border-rose-300
                        text-sm font-semibold rounded-xl transition cursor-pointer" do %>
            Delete Project
          <% end %>
        <% end %>
      </div>
    </div>
  </div>

</div>
