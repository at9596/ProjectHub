<%# Organization Settings %>
<div class="max-w-3xl mx-auto space-y-8">

  <%# Header %>
  <div>
    <h1 class="text-3xl font-extrabold text-slate-900">Workspace Settings</h1>
    <p class="mt-1 text-sm text-slate-500"><%= @organization.name %></p>
  </div>

  <%# General Settings Card %>
  <div class="bg-white border border-slate-100 rounded-2xl shadow-sm overflow-hidden">
    <div class="h-1 w-full bg-gradient-to-r from-indigo-500 via-purple-500 to-pink-500"></div>
    <div class="p-6">
      <h2 class="text-lg font-bold text-slate-800 mb-4">General</h2>
      <%= form_with model: @organization, url: organization_path, method: :patch, class: "space-y-4" do |f| %>
        <div>
          <%= f.label :name, "Workspace name", class: "block text-sm font-semibold text-slate-700 mb-1.5" %>
          <%= f.text_field :name, class: "block w-full px-4 py-2.5 rounded-xl border border-slate-200 text-slate-800
                                          text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 transition" %>
        </div>
        <%= f.submit "Save Changes", class: "px-5 py-2.5 bg-indigo-600 hover:bg-indigo-700 text-white text-sm
                                            font-semibold rounded-xl transition cursor-pointer" %>
      <% end %>
    </div>
  </div>

  <%# Members Card %>
  <div class="bg-white border border-slate-100 rounded-2xl shadow-sm overflow-hidden">
    <div class="p-6">
      <div class="flex items-center justify-between mb-4">
        <h2 class="text-lg font-bold text-slate-800">Members <span class="text-slate-400 font-normal text-base">(<%= @members.count %>)</span></h2>
      </div>

      <ul class="divide-y divide-slate-100">
        <% @members.each do |member| %>
          <li class="flex items-center justify-between py-3 gap-3">
            <div class="flex items-center gap-3">
              <span class="inline-flex items-center justify-center w-9 h-9 rounded-full bg-indigo-100 text-indigo-600 text-sm font-bold uppercase">
                <%= (member.name || member.email).first %>
              </span>
              <div>
                <p class="text-sm font-semibold text-slate-800"><%= member.name || member.email %></p>
                <p class="text-xs text-slate-400"><%= member.email %></p>
              </div>
            </div>
            <% role_colors = { "owner" => "bg-purple-100 text-purple-700", "admin" => "bg-blue-100 text-blue-700",
                               "member" => "bg-slate-100 text-slate-600", "viewer" => "bg-gray-100 text-gray-500" } %>
            <span class="text-xs font-semibold px-2.5 py-1 rounded-full <%= role_colors[member.role] || 'bg-slate-100 text-slate-600' %>">
              <%= member.role.humanize %>
            </span>
          </li>
        <% end %>
      </ul>
    </div>
  </div>

  <%# Invite Member Card %>
  <% if policy(current_user.organization).update? %>
    <div class="bg-white border border-slate-100 rounded-2xl shadow-sm overflow-hidden">
      <div class="p-6">
        <h2 class="text-lg font-bold text-slate-800 mb-4">Invite a Team Member</h2>
        <%= form_with url: user_invitation_path, method: :post, class: "flex flex-wrap gap-3 items-end" do |f| %>
          <div class="flex-1 min-w-[200px]">
            <label class="block text-sm font-semibold text-slate-700 mb-1.5">Email address</label>
            <input type="email" name="user[email]" placeholder="colleague@company.com" required
                   class="block w-full px-4 py-2.5 rounded-xl border border-slate-200 text-slate-800
                           text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 transition">
          </div>
          <div>
            <label class="block text-sm font-semibold text-slate-700 mb-1.5">Role</label>
            <select name="user[role]" class="px-4 py-2.5 rounded-xl border border-slate-200 text-slate-800
                                              text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 transition bg-white">
              <option value="member">Member</option>
              <option value="admin">Admin</option>
              <option value="viewer">Viewer</option>
            </select>
          </div>
          <button type="submit" class="px-5 py-2.5 bg-indigo-600 hover:bg-indigo-700 text-white text-sm
                                        font-semibold rounded-xl transition cursor-pointer">
            Send Invitation
          </button>
        <% end %>
      </div>
    </div>
  <% end %>

</div>
