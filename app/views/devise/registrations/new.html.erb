<%# Sign Up Page %>
<div class="min-h-screen flex items-center justify-center bg-gradient-to-br from-slate-900 via-indigo-950 to-slate-900 px-4">
  <div class="w-full max-w-md">

    <%# Logo / Brand %>
    <div class="text-center mb-8">
      <div class="inline-flex items-center justify-center w-14 h-14 bg-indigo-600 rounded-2xl shadow-xl shadow-indigo-900/50 mb-4">
        <svg class="w-7 h-7 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                d="M9 13h6m-3-3v6m-9 1V7a2 2 0 012-2h6l2 2h6a2 2 0 012 2v8a2 2 0 01-2 2H5a2 2 0 01-2-2z"/>
        </svg>
      </div>
      <h1 class="text-3xl font-extrabold text-white">Create your workspace</h1>
      <p class="mt-1 text-slate-400 text-sm">Free forever. No credit card required.</p>
    </div>

    <%# Card %>
    <div class="bg-white/5 backdrop-blur border border-white/10 rounded-2xl p-8 shadow-2xl">
      <%= render "devise/shared/error_messages", resource: resource %>

      <%= form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f| %>

        <%# Workspace Name %>
        <div class="mb-4">
          <label class="block text-xs font-semibold text-slate-300 uppercase tracking-wider mb-1.5">Workspace / Company Name</label>
          <input type="text" name="user[organization_name]" placeholder="e.g. Acme Corp"
                 class="block w-full px-4 py-2.5 rounded-xl bg-white/10 border border-white/20
                        text-white placeholder-slate-500 text-sm focus:outline-none focus:ring-2
                        focus:ring-indigo-500 focus:border-transparent transition">
        </div>

        <%# Full Name %>
        <div class="mb-4">
          <%= f.label :name, class: "block text-xs font-semibold text-slate-300 uppercase tracking-wider mb-1.5" %>
          <%= f.text_field :name, autofocus: true, autocomplete: "name", placeholder: "Your full name",
                class: "block w-full px-4 py-2.5 rounded-xl bg-white/10 border border-white/20
                        text-white placeholder-slate-500 text-sm focus:outline-none focus:ring-2
                        focus:ring-indigo-500 focus:border-transparent transition" %>
        </div>

        <%# Email %>
        <div class="mb-4">
          <%= f.label :email, class: "block text-xs font-semibold text-slate-300 uppercase tracking-wider mb-1.5" %>
          <%= f.email_field :email, autocomplete: "email", placeholder: "you@company.com",
                class: "block w-full px-4 py-2.5 rounded-xl bg-white/10 border border-white/20
                        text-white placeholder-slate-500 text-sm focus:outline-none focus:ring-2
                        focus:ring-indigo-500 focus:border-transparent transition" %>
        </div>

        <%# Password %>
        <div class="mb-4">
          <%= f.label :password, class: "block text-xs font-semibold text-slate-300 uppercase tracking-wider mb-1.5" %>
          <% if @minimum_password_length %>
            <p class="text-slate-500 text-xs mb-1">(<%= @minimum_password_length %> characters minimum)</p>
          <% end %>
          <%= f.password_field :password, autocomplete: "new-password", placeholder: "••••••••",
                class: "block w-full px-4 py-2.5 rounded-xl bg-white/10 border border-white/20
                        text-white placeholder-slate-500 text-sm focus:outline-none focus:ring-2
                        focus:ring-indigo-500 focus:border-transparent transition" %>
        </div>

        <%# Confirm Password %>
        <div class="mb-6">
          <%= f.label :password_confirmation, "Confirm Password", class: "block text-xs font-semibold text-slate-300 uppercase tracking-wider mb-1.5" %>
          <%= f.password_field :password_confirmation, autocomplete: "new-password", placeholder: "••••••••",
                class: "block w-full px-4 py-2.5 rounded-xl bg-white/10 border border-white/20
                        text-white placeholder-slate-500 text-sm focus:outline-none focus:ring-2
                        focus:ring-indigo-500 focus:border-transparent transition" %>
        </div>

        <%= f.submit "Create Workspace & Account",
              class: "w-full py-3 bg-indigo-600 hover:bg-indigo-500 active:scale-98 text-white
                      font-bold text-sm rounded-xl shadow-lg shadow-indigo-900/40 transition-all
                      duration-150 cursor-pointer" %>
      <% end %>

      <p class="mt-6 text-center text-slate-400 text-sm">
        Already have an account?
        <%= link_to "Sign in →", new_user_session_path, class: "text-indigo-400 hover:text-indigo-300 font-semibold transition" %>
      </p>
    </div>
  </div>
</div>
