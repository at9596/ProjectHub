<% if pagy.next %>
  <%= turbo_frame_tag "pagination",
      loading: :lazy,
      src: projects_path(page: pagy.next, format: :turbo_stream),
      class: "block" do %>
    <div class="flex justify-center py-6">
      <div class="flex items-center gap-2 px-5 py-2.5 bg-white border border-slate-200
                  rounded-xl shadow-sm text-sm text-slate-500">
        <svg class="w-4 h-4 animate-spin text-indigo-500" fill="none" viewBox="0 0 24 24">
          <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/>
          <path class="opacity-75" fill="currentColor"
                d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"/>
        </svg>
        Loading more projects…
      </div>
    </div>
  <% end %>
<% end %>