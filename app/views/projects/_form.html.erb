<%# Shared form for new & edit %>
<%= form_with model: project, class: "space-y-6" do |f| %>

  <%# Flash validation errors %>
  <% if project.errors.any? %>
    <div class="flex gap-3 p-4 bg-rose-50 border border-rose-200 rounded-xl text-sm text-rose-700">
      <svg class="w-5 h-5 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z"/>
      </svg>
      <div>
        <p class="font-semibold mb-1"><%= pluralize(project.errors.count, "error") %> prevented saving:</p>
        <ul class="list-disc list-inside space-y-0.5">
          <% project.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
          <% end %>
        </ul>
      </div>
    </div>
  <% end %>

  <%# Name %>
  <div class="space-y-1.5">
    <%= f.label :name, class: "block text-sm font-semibold text-slate-700" %>
    <%= f.text_field :name,
          placeholder: "e.g. Website Redesign",
          class: "block w-full px-4 py-2.5 rounded-xl border border-slate-200 bg-white
                  text-slate-800 placeholder-slate-400 text-sm shadow-sm
                  focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500
                  transition" %>
  </div>

  <%# Description %>
  <div class="space-y-1.5">
    <%= f.label :description, class: "block text-sm font-semibold text-slate-700" %>
    <%= f.text_area :description,
          rows: 4,
          placeholder: "Briefly describe the project goals…",
          class: "block w-full px-4 py-2.5 rounded-xl border border-slate-200 bg-white
                  text-slate-800 placeholder-slate-400 text-sm shadow-sm resize-none
                  focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500
                  transition" %>
  </div>

  <%# Status + Due date — 2-col grid %>
  <div class="grid sm:grid-cols-2 gap-6">

    <%# Status %>
    <div class="space-y-1.5">
      <%= f.label :status, class: "block text-sm font-semibold text-slate-700" %>
      <%= f.select :status,
            Project.statuses.keys.map { |s| [s.humanize, s] },
            {},
            class: "block w-full px-4 py-2.5 rounded-xl border border-slate-200 bg-white
                    text-slate-800 text-sm shadow-sm
                    focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500
                    transition" %>
    </div>

    <%# Due date %>
    <div class="space-y-1.5">
      <%= f.label :due_date, class: "block text-sm font-semibold text-slate-700" %>
      <%= f.date_field :due_date,
            class: "block w-full px-4 py-2.5 rounded-xl border border-slate-200 bg-white
                    text-slate-800 text-sm shadow-sm
                    focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500
                    transition" %>
    </div>

  </div>

  <%# Form actions %>
  <div class="flex items-center gap-3 pt-2">
    <%= f.submit project.persisted? ? "Save Changes" : "Create Project",
          class: "px-6 py-2.5 bg-indigo-600 hover:bg-indigo-700 active:scale-95
                  text-white text-sm font-semibold rounded-xl shadow-md shadow-indigo-200
                  transition-all duration-150 cursor-pointer" %>

    <%= link_to project.persisted? ? project : projects_path,
          class: "px-5 py-2.5 text-sm font-semibold text-slate-500 hover:text-slate-700
                  border border-slate-200 rounded-xl hover:bg-slate-50 transition-all duration-150" do %>
      Cancel
    <% end %>
  </div>

<% end %>
