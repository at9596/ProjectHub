<%# Edit Project Page %>
<div class="max-w-2xl mx-auto">

  <%# Breadcrumb %>
  <nav class="flex items-center gap-2 text-sm text-slate-400 mb-6">
    <%= link_to "Projects", projects_path, class: "hover:text-indigo-600 transition" %>
    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
    </svg>
    <%= link_to @project.name, @project, class: "hover:text-indigo-600 transition truncate max-w-[180px]" %>
    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
    </svg>
    <span class="text-slate-600 font-medium">Edit</span>
  </nav>

  <%# Card %>
  <div class="bg-white border border-slate-100 rounded-2xl shadow-sm overflow-hidden">
    <div class="h-1 w-full bg-gradient-to-r from-amber-400 via-orange-400 to-pink-500"></div>

    <div class="p-8">
      <div class="flex items-start justify-between gap-4 mb-8">
        <div>
          <h1 class="text-2xl font-extrabold text-slate-900">Edit Project</h1>
          <p class="mt-1 text-sm text-slate-500">Update the details for <span class="font-semibold text-slate-700"><%= @project.name %></span>.</p>
        </div>
        <%# Quick status badge %>
        <% s = { "active" => %w[bg-emerald-100 text-emerald-700],
                 "completed" => %w[bg-blue-100 text-blue-700],
                 "archived" => %w[bg-slate-100 text-slate-500] }[@project.status] || %w[bg-slate-100 text-slate-500] %>
        <span class="shrink-0 inline-flex items-center px-3 py-1 rounded-full text-xs font-semibold <%= s.join(" ") %>">
          <%= @project.status.humanize %>
        </span>
      </div>

      <%= render "form", project: @project %>
    </div>
  </div>

</div>
