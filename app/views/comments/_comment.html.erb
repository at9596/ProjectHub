<%# Comment Partial %>
<div class="flex gap-3 items-start" id="comment_<%= comment.id %>">
  <span class="inline-flex items-center justify-center w-8 h-8 rounded-full bg-slate-100 text-slate-600
               text-sm font-bold uppercase shrink-0 mt-0.5">
    <%= comment.user.email.first %>
  </span>
  <div class="flex-1 bg-slate-50 rounded-xl p-4">
    <div class="flex items-center justify-between mb-1">
      <span class="text-sm font-semibold text-slate-700">
        <%= comment.user.name || comment.user.email %>
      </span>
      <div class="flex items-center gap-3">
        <span class="text-xs text-slate-400"><%= time_ago_in_words(comment.created_at) %> ago</span>
        <% if policy(comment).destroy? %>
          <%= button_to [comment.commentable.project, comment.commentable, comment],
                method: :delete,
                data: { turbo_confirm: "Delete this comment?" },
                class: "text-xs text-slate-400 hover:text-rose-500 transition cursor-pointer" do %>
            ✕
          <% end %>
        <% end %>
      </div>
    </div>
    <%# Render @mentions highlighted %>
    <p class="text-sm text-slate-700 whitespace-pre-line">
      <%= comment.body.gsub(/@(\w+)/) { "<span class=\"text-indigo-600 font-semibold\">@#{$1}</span>" }.html_safe %>
    </p>
  </div>
</div>
