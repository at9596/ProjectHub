<nav class="fixed top-0 left-0 right-0 z-50 bg-slate-900/95 backdrop-blur border-b border-white/10 px-6 py-3">
  <div class="max-w-7xl mx-auto flex items-center justify-between gap-4">

    <%# Brand %>
    <%= link_to projects_path, class: "flex items-center gap-2.5 shrink-0" do %>
      <div class="w-8 h-8 bg-indigo-600 rounded-lg flex items-center justify-center shadow-md">
        <svg class="w-4 h-4 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                d="M9 13h6m-3-3v6m-9 1V7a2 2 0 012-2h6l2 2h6a2 2 0 012 2v8a2 2 0 01-2 2H5a2 2 0 01-2-2z"/>
        </svg>
      </div>
      <span class="text-white font-bold text-lg tracking-tight">ProjectHub</span>
    <% end %>

    <% if user_signed_in? %>
      <%# Nav links %>
      <div class="hidden sm:flex items-center gap-1">
        <%= link_to "Projects", projects_path,
              class: "px-3 py-1.5 text-sm text-slate-300 hover:text-white hover:bg-white/10 rounded-lg transition" %>
        <%= link_to "Labels", labels_path,
              class: "px-3 py-1.5 text-sm text-slate-300 hover:text-white hover:bg-white/10 rounded-lg transition" %>
        <%= link_to "Settings", organization_path,
              class: "px-3 py-1.5 text-sm text-slate-300 hover:text-white hover:bg-white/10 rounded-lg transition" %>
      </div>

      <%# Right side %>
      <div class="flex items-center gap-2">

        <%# Notification bell %>
        <% unread_count = current_user.notifications.unread.count %>
        <%= link_to notifications_path,
              class: "relative inline-flex items-center justify-center w-9 h-9 rounded-lg
                      text-slate-400 hover:text-white hover:bg-white/10 transition" do %>
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                  d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"/>
          </svg>
          <% if unread_count > 0 %>
            <span class="absolute -top-0.5 -right-0.5 flex items-center justify-center
                         w-4 h-4 rounded-full bg-rose-500 text-white text-[10px] font-bold">
              <%= unread_count > 9 ? "9+" : unread_count %>
            </span>
          <% end %>
        <% end %>

        <%# User menu %>
        <div class="flex items-center gap-2 pl-2 border-l border-white/10">
          <span class="inline-flex items-center justify-center w-8 h-8 rounded-full
                       bg-indigo-600 text-white text-sm font-bold uppercase">
            <%= (current_user.name || current_user.email).first %>
          </span>
          <span class="hidden sm:block text-sm text-slate-300 max-w-[120px] truncate">
            <%= current_user.name || current_user.email %>
          </span>
          <%= button_to destroy_user_session_path, method: :delete,
                class: "ml-1 text-xs text-slate-400 hover:text-rose-400 transition cursor-pointer px-2 py-1 rounded-lg hover:bg-white/5" do %>
            Sign out
          <% end %>
        </div>
      </div>
    <% else %>
      <div class="flex items-center gap-2">
        <%= link_to "Sign in", new_user_session_path,
              class: "px-4 py-2 text-sm text-slate-300 hover:text-white transition" %>
        <%= link_to "Get started", new_user_registration_path,
              class: "px-4 py-2 bg-indigo-600 hover:bg-indigo-500 text-white text-sm font-semibold rounded-xl transition" %>
      </div>
    <% end %>
  </div>
</nav>