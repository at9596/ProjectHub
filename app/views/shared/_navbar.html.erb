<nav class="bg-gray-800 text-white px-6 py-4">
  <div class="flex justify-between items-center">
    <h1 class="text-xl font-bold">ProjectHub</h1>

    <div class="space-x-4">
      <% if user_signed_in? %>
        <span>
          Welcome, <%= current_user.name || current_user.email %>
        </span>

        <%= button_to "Sign Out",
                      destroy_user_session_path,
                      method: :delete,
                      class: "bg-red-500 hover:bg-red-600 px-4 py-2 rounded" %>
      <% else %>
        <%= link_to "Sign In",
                    new_user_session_path,
                    class: "bg-blue-500 hover:bg-blue-600 px-4 py-2 rounded" %>

        <%= link_to "Sign Up",
                    new_user_registration_path,
                    class: "bg-green-500 hover:bg-green-600 px-4 py-2 rounded" %>
      <% end %>
    </div>
  </div>
</nav>