<%# Notifications Index %>
<div class="max-w-2xl mx-auto">
  <div class="flex items-center justify-between mb-8">
    <h1 class="text-3xl font-extrabold text-slate-900">Notifications</h1>
    <% if @notifications.any?(&:read?.tap {}) %>
    <% end %>
    <%= button_to mark_all_read_notifications_path, method: :patch,
          class: "text-sm text-slate-500 hover:text-indigo-600 border border-slate-200
                  px-4 py-2 rounded-xl hover:bg-indigo-50 transition cursor-pointer" do %>
      Mark all read
    <% end %>
  </div>

  <div class="bg-white border border-slate-100 rounded-2xl shadow-sm overflow-hidden">
    <% if @notifications.any? %>
      <ul class="divide-y divide-slate-100">
        <% @notifications.each do |n| %>
          <li class="flex items-start gap-4 px-6 py-4 <%= n.read? ? 'bg-white' : 'bg-indigo-50/40' %>">
            <%# Actor avatar %>
            <span class="inline-flex items-center justify-center w-9 h-9 rounded-full
                         bg-indigo-100 text-indigo-600 text-sm font-bold uppercase shrink-0 mt-0.5">
              <%= n.actor.email.first %>
            </span>

            <div class="flex-1 min-w-0">
              <p class="text-sm text-slate-800"><%= n.message %></p>
              <p class="text-xs text-slate-400 mt-0.5"><%= time_ago_in_words(n.created_at) %> ago</p>
            </div>

            <% unless n.read? %>
              <span class="inline-block w-2 h-2 rounded-full bg-indigo-500 mt-2 shrink-0"></span>
            <% end %>
          </li>
        <% end %>
      </ul>
    <% else %>
      <div class="flex flex-col items-center justify-center py-16 text-center">
        <div class="w-12 h-12 bg-slate-100 rounded-full flex items-center justify-center mb-3">
          <svg class="w-6 h-6 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                  d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"/>
          </svg>
        </div>
        <p class="text-slate-500 text-sm font-medium">You're all caught up!</p>
        <p class="text-slate-400 text-xs mt-1">No notifications yet.</p>
      </div>
    <% end %>
  </div>
</div>
